# Admin
ADMIN_EMAIL="na5893395@gmail.com"

# App
PORT=4000
NODE_ENV="development"
FRONTEND_URL="http://localhost:3000"

# Upload
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE=5242880

# Rate Limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=100
